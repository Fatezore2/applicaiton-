<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3FBFB"
> <!-- add top padding to push content below status bar -->
 <!-- makes the scroll view respect system bars -->

    <LinearLayout
        android:id="@+id/homeRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ================= App Bar ================= -->
        <LinearLayout
            android:id="@+id/layoutAppBar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvLogo"
                android:layout_width="50dp"
                android:layout_height="48dp"
                android:background="#2EC4C1"
                android:gravity="center"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/layoutBrand"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Trip"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAppSlogan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Plan · Sync · Explore"
                    android:textColor="#6B7B86"
                    android:textSize="12sp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/setting"
                android:layout_width="50dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:src="@drawable/gear"
                android:tint="@android:color/black" />


        </LinearLayout>

        <!-- ================= Map Card (FIXED) ================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMap"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="267dp"
                    app:mapId="YOUR_MAP_ID_HERE" />

                <View
                    android:id="@+id/map_transparent_overlay"
                    android:layout_width="match_parent"
                    android:layout_height="267dp"
                    android:background="@android:color/transparent" />

                <LinearLayout
                    android:id="@+id/layoutTripSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:padding="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#F9FFFF">

                    <LinearLayout
                        android:id="@+id/layoutTripInfo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/btnMyLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:text="📍 My Location" />

                        <TextView
                            android:id="@+id/tvTripTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="尚未加入群組"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
        <!-- ================= Destination List ================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDestinations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:id="@+id/layoutDestinationRoot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDestinationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 行程目的地"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:id="@+id/layoutDestinationList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp"/>

                <Button
                    android:id="@+id/btnMoreOptions"

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="#2EC4C1"
                    android:text="➕ 新增目的地"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= Create / Join ================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCreateJoin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:id="@+id/layoutCreateJoin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp">


                <LinearLayout
                    android:id="@+id/layoutCreateButtons"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">


                    <Button
                        android:id="@+id/btnOpenGroup"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="更多方式" />

                    <Button
                        android:id="@+id/getgrounp"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="getingrounp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
