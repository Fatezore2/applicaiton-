<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#12000000" /> </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white" />
            <stroke
                android:width="1dp"
                android:color="#0D000000" /> </shape>
    </item>
</layer-list>